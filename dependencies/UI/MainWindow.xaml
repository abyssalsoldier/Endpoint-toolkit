<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Endpoint Toolkit" Height="780" Width="1200"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E" Foreground="#FFCDD6F4">

    <Window.Resources>
        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="PanelBg" Color="#FF2D2D44"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#FF3D3D5C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF89B4FA"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFCDD6F4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFA6ADC8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF9E2AF"/>
        <SolidColorBrush x:Key="ButtonBg" Color="#FF3D3D5C"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#FF4D4D6C"/>
        <SolidColorBrush x:Key="InputBg" Color="#FF1E1E2E"/>

        <!-- Button style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox style — use system default template, just set font size -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- ComboBoxItem style (dropdown items) -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBlock style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- Label style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="50"/>
            <!-- Main content (nav + action) -->
            <RowDefinition Height="*"/>
            <!-- Splitter -->
            <RowDefinition Height="Auto"/>
            <!-- Log panel -->
            <RowDefinition Height="200" MinHeight="80"/>
        </Grid.RowDefinitions>

        <!-- ============ TITLE BAR ============ -->
        <Border Grid.Row="0" Background="#FF181825" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0">
                <TextBlock Text="Endpoint Toolkit" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <TextBlock Name="txtVersion" Text="v1.0.0" FontSize="13"
                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                           Margin="10,0,0,0" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            DockPanel.Dock="Right">
                    <TextBlock Name="txtAuthIcon" Text="&#x1F512;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Name="txtAuthStatus" Text="Locked" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============ MAIN CONTENT ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Nav panel -->
                <ColumnDefinition Width="220" MinWidth="160"/>
                <!-- Action panel -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- NAV PANEL -->
            <Border Grid.Column="0" Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Bottom buttons: Session Report + Quit -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,10">
                        <Separator Background="{StaticResource PanelBorder}" Margin="0,0,0,8"/>
                        <Button Name="btnUsbToolkit" Content="USB Toolkit" Margin="0,0,0,6"
                                HorizontalAlignment="Stretch"/>
                        <Button Name="btnSessionReport" Content="Session Report" Margin="0,0,0,6"
                                HorizontalAlignment="Stretch"/>
                        <Button Name="btnQuit" Content="Quit" HorizontalAlignment="Stretch"
                                Background="#FF45243D" Foreground="{StaticResource ErrorBrush}"/>
                    </StackPanel>

                    <!-- Module list -->
                    <StackPanel Margin="10,10,10,0">
                        <TextBlock Text="MODULES" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondary}" Margin="6,0,0,8"/>
                        <ListBox Name="lstModules" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextPrimary}" FontSize="14">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#FF3D3D5C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#FF3D3D5C"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ACTION PANEL -->
            <Border Grid.Column="1" Margin="0">
                <ContentControl Name="ActionContent" Margin="24,20">
                    <!-- Default placeholder -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Select a module from the list" FontSize="16"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </ContentControl>
            </Border>
        </Grid>

        <!-- ============ SPLITTER ============ -->
        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                      Background="{StaticResource PanelBorder}" ResizeDirection="Rows"/>

        <!-- ============ LOG PANEL ============ -->
        <Border Grid.Row="3" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="LOG OUTPUT" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}" Margin="12,8,0,4"
                           DockPanel.Dock="Top"/>
                <RichTextBox Name="LogOutput" IsReadOnly="True"
                             Background="Transparent" Foreground="{StaticResource TextPrimary}"
                             BorderThickness="0" FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" Margin="8,0,8,8"
                             IsDocumentEnabled="True">
                    <RichTextBox.Document>
                        <FlowDocument PagePadding="0">
                            <Paragraph Name="LogParagraph"/>
                        </FlowDocument>
                    </RichTextBox.Document>
                </RichTextBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
