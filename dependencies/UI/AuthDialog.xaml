<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Toolkit Authentication" Height="220" Width="420"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E2E"
        Foreground="#FFCDD6F4" ResizeMode="NoResize"
        WindowStyle="ToolWindow" Topmost="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Toolkit Password" FontSize="18" FontWeight="Bold"
                   Foreground="#FF89B4FA" Grid.Row="0" Margin="0,0,0,6"/>
        <TextBlock Name="txtAuthMsg" Text="Enter the toolkit password to unlock all features."
                   FontSize="12" Foreground="#FFA6ADC8" Grid.Row="1" Margin="0,0,0,12" TextWrapping="Wrap"/>
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="34"/>
            </Grid.ColumnDefinitions>
            <PasswordBox Name="txtPassword" Grid.Column="0" Height="32" FontSize="14"
                         Background="#FF2D2D44" Foreground="#FFCDD6F4"
                         BorderBrush="#FF3D3D5C"/>
            <TextBox Name="txtPasswordReveal" Grid.Column="0" Height="32" FontSize="14"
                     Background="#FF2D2D44" Foreground="#FFCDD6F4"
                     BorderBrush="#FF3D3D5C" Visibility="Collapsed" VerticalContentAlignment="Center"/>
            <Button Name="btnReveal" Grid.Column="1" Height="32" Margin="2,0,0,0"
                    Background="#FF3D3D5C" Foreground="#FFCDD6F4" FontSize="16"
                    BorderThickness="0" Cursor="Hand" Content="&#x1F441;"
                    ToolTip="Reveal Password"/>
        </Grid>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="btnSkip" Content="Skip" Grid.Column="0" Height="34"
                    Background="#FF3D3D5C" Foreground="#FFCDD6F4" FontSize="13"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Name="btnUnlock" Content="Unlock" Grid.Column="2" Height="34"
                    Background="#FF89B4FA" Foreground="#FF1E1E2E" FontSize="13"
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
